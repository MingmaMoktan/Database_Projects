# ====================================================================
# DATABASE & DOCKER (The most important for this project)
# ====================================================================
# Ignore the actual SQL Server data files stored in your Docker volume
mssql_data/

# Ignore raw datasets - keep your repo for code, not bulk data
datasets/*.csv
datasets/*.xlsx
*.csv
*.xlsx

# ====================================================================
# PYTHON & ENVIRONMENTS
# ====================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ====================================================================
# DATA TOOLS (DBeaver & dbt)
# ====================================================================
# DBeaver settings (Ignore UI layout and data sources with credentials)
.dbeaver/
.dbeaver-data-sources.xml
Scripts/General/

# dbt (Data Build Tool) - Ignore compiled code and logs
target/
dbt_packages/
logs/
dbt_modules/

# ====================================================================
# SECRETS & IDE SETTINGS
# ====================================================================
# Connection profiles and secrets
profiles.yml
*.user
.envrc

# IDEs (Uncomment if you want to ignore these specifically)
#.vscode/
#.idea/
.cursorignore
.cursorindexingignore

# System Files
.DS_Store
Thumbs.db